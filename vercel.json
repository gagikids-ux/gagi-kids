{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/admin",     "destination": "/api/index.js" },
    { "source": "/catalogo",  "destination": "/api/index.js" },
    { "source": "/(.*)",      "destination": "/index.html"   }
  ]
}
